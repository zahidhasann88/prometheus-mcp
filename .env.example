# Required: base URL of your Prometheus server (no trailing slash needed).
PROMETHEUS_URL=http://localhost:9090

# Optional auth — use ONE of these blocks, or leave unset for unauthenticated Prometheus.

# Bearer token (e.g. Grafana Cloud, Amazon Managed Prometheus via sigv4 proxy):
# PROMETHEUS_BEARER_TOKEN=eyJhbGciOi...

# HTTP Basic auth:
# PROMETHEUS_USERNAME=admin
# PROMETHEUS_PASSWORD=changeme

# Optional: request timeout in milliseconds (default 30000).
# PROMETHEUS_TIMEOUT_MS=30000

# Optional: log level — debug | info | warn | error (default info).
# LOG_LEVEL=info
